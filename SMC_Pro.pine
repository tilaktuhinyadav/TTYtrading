//@version=6
indicator("SMC Pro", shorttitle="SMC Pro", overlay=true, max_boxes_count=300, max_lines_count=300, max_labels_count=300)

//=============================================================================
// 1. Constants & Inputs
//=============================================================================
const int TREND_BULL = 1
const int TREND_BEAR = -1
const int TREND_NEUTRAL = 0
const int DIR_BULL = 1
const int DIR_BEAR = -1

string groupGeneral = "General"
string groupStructure = "Market Structure"
string groupFvg = "Fair Value Gaps"
string groupOb = "Order Blocks"
string groupLiq = "Liquidity"
string groupPd = "Premium / Discount"
string groupMtf = "Multi-Timeframe"
string groupSessions = "Sessions"
string groupSignals = "Smart Signals"
string groupStyle = "Colors"

bool showSwings = input.bool(true, "Show Swings", group=groupGeneral)
bool showBos = input.bool(true, "Enable BOS", group=groupGeneral)
bool showChoch = input.bool(true, "Enable CHoCH", group=groupGeneral)
bool showFvg = input.bool(true, "Enable FVG", group=groupGeneral)
bool showOb = input.bool(true, "Enable Order Blocks", group=groupGeneral)
bool showLiquidity = input.bool(true, "Enable Liquidity", group=groupGeneral)
bool showPd = input.bool(true, "Enable Premium / Discount", group=groupGeneral)
bool showMtf = input.bool(true, "Enable MTF", group=groupGeneral)
bool showSessions = input.bool(true, "Enable Sessions", group=groupGeneral)
bool showDashboard = input.bool(true, "Enable Dashboard", group=groupGeneral)
bool showSignals = input.bool(true, "Enable Smart Signals", group=groupGeneral)

int pivotLen = input.int(5, "Pivot Length", minval=2, maxval=50, group=groupStructure)
string breakMode = input.string("Close", "Break Confirmation", options=["Close", "Wick"], group=groupStructure)
bool useBosAtrFilter = input.bool(true, "Use ATR Break Filter", group=groupStructure)
float bosAtrMult = input.float(0.10, "BOS ATR Multiplier", minval=0.0, step=0.05, group=groupStructure)
int atrLen = input.int(14, "ATR Length", minval=1, group=groupStructure)
int recentBars = input.int(20, "Recent Event Window", minval=1, maxval=200, group=groupStructure)

bool useFvgAtrFilter = input.bool(true, "Use ATR Gap Filter", group=groupFvg)
float fvgAtrMult = input.float(0.15, "FVG ATR Multiplier", minval=0.0, step=0.05, group=groupFvg)
float minGapTicks = input.float(1.0, "Minimum Gap Size (ticks)", minval=0.0, step=0.5, group=groupFvg)
int maxFvgs = input.int(20, "Maximum Active FVGs", minval=1, maxval=100, group=groupFvg)
int fvgExtendBars = input.int(100, "Extend Bars", minval=1, maxval=500, group=groupFvg)
bool deleteFilledFvg = input.bool(true, "Delete Filled FVG", group=groupFvg)

int maxObs = input.int(20, "Maximum Active OBs", minval=1, maxval=100, group=groupOb)
int obExtendBars = input.int(120, "Extend Bars", minval=1, maxval=500, group=groupOb)
bool removeInvalidOb = input.bool(true, "Remove Invalid OB", group=groupOb)
bool showBreakerBlocks = input.bool(true, "Mark Breaker Blocks", group=groupOb)

float equalToleranceAtr = input.float(0.10, "Equal High/Low Tolerance ATR", minval=0.0, step=0.05, group=groupLiq)
int liquidityExtendBars = input.int(80, "Liquidity Line Extend Bars", minval=5, maxval=500, group=groupLiq)

int pdExtendBars = input.int(120, "Zone Extend Bars", minval=10, maxval=500, group=groupPd)

string htf = input.timeframe("240", "Higher Timeframe", group=groupMtf)
int htfTrendLen = input.int(50, "HTF Trend MA Length", minval=2, group=groupMtf)

string asianSession = input.session("0000-0600", "Asian Session", group=groupSessions)
string londonSession = input.session("0700-1000", "London Kill Zone", group=groupSessions)
string nySession = input.session("1230-1600", "New York Kill Zone", group=groupSessions)

bool requireVolumeConfirm = input.bool(false, "Require Volume Confirmation", group=groupSignals)
int volumeMaLen = input.int(20, "Volume MA Length", minval=1, group=groupSignals)
float rr1 = input.float(1.0, "TP1 R:R", minval=0.1, step=0.1, group=groupSignals)
float rr2 = input.float(2.0, "TP2 R:R", minval=0.1, step=0.1, group=groupSignals)
float rr3 = input.float(3.0, "TP3 R:R", minval=0.1, step=0.1, group=groupSignals)

color bullColor = input.color(color.rgb(0, 170, 120), "Bullish", group=groupStyle)
color bearColor = input.color(color.rgb(220, 70, 70), "Bearish", group=groupStyle)
color neutralColor = input.color(color.rgb(140, 140, 140), "Neutral", group=groupStyle)
color fvgBullColor = input.color(color.rgb(38, 166, 154), "Bullish FVG", group=groupStyle)
color fvgBearColor = input.color(color.rgb(239, 83, 80), "Bearish FVG", group=groupStyle)
color obBullColor = input.color(color.rgb(46, 125, 50), "Bullish OB", group=groupStyle)
color obBearColor = input.color(color.rgb(198, 40, 40), "Bearish OB", group=groupStyle)

//=============================================================================
// 2. Utility Functions
//=============================================================================
float atr = ta.atr(atrLen)
float minTickGap = minGapTicks * syminfo.mintick
float breakBuffer = useBosAtrFilter ? atr * bosAtrMult : 0.0
float breakHighSource = breakMode == "Close" ? close : high
float breakLowSource = breakMode == "Close" ? close : low

string f_trendText(int trend) =>
    trend == TREND_BULL ? "Bullish" : trend == TREND_BEAR ? "Bearish" : "Neutral"

color f_trendColor(int trend) =>
    trend == TREND_BULL ? bullColor : trend == TREND_BEAR ? bearColor : neutralColor

bool f_recent(bool condition, int bars) =>
    int since = ta.barssince(condition)
    not na(since) and since <= bars

bool f_inSession(string sess) =>
    not na(time(timeframe.period, sess))

string f_sessionName() =>
    f_inSession(asianSession) ? "Asian" : f_inSession(londonSession) ? "London" : f_inSession(nySession) ? "New York" : "Off"

void f_trimBoxes(box[] boxes, int[] dirs, int maxCount) =>
    while array.size(boxes) > maxCount
        box oldBox = array.shift(boxes)
        array.shift(dirs)
        box.delete(oldBox)

void f_trimLines(line[] lines, int maxCount) =>
    while array.size(lines) > maxCount
        line oldLine = array.shift(lines)
        line.delete(oldLine)

int f_countDir(int[] dirs, int dir) =>
    int count = 0
    if array.size(dirs) > 0
        for i = 0 to array.size(dirs) - 1
            count += array.get(dirs, i) == dir ? 1 : 0
    count

//=============================================================================
// 3. Drawing Manager State
//=============================================================================
var box[] fvgBoxes = array.new_box()
var int[] fvgDirs = array.new_int()
var box[] obBoxes = array.new_box()
var int[] obDirs = array.new_int()
var line[] liquidityLines = array.new_line()
var line eqLine = na
var box premiumBox = na
var box discountBox = na
var box oteBox = na
var table dash = table.new(position.top_right, 2, 9, bgcolor=color.new(color.black, 10), frame_color=color.new(color.white, 70), frame_width=1)

//=============================================================================
// 4. Swing Detection Engine
//=============================================================================
float ph = ta.pivothigh(high, pivotLen, pivotLen)
float pl = ta.pivotlow(low, pivotLen, pivotLen)
bool newSwingHigh = not na(ph)
bool newSwingLow = not na(pl)
int pivotIndex = bar_index - pivotLen

var float prevSwingHigh = na
var float lastSwingHigh = na
var int lastSwingHighIndex = na
var string lastHighType = ""
var float prevSwingLow = na
var float lastSwingLow = na
var int lastSwingLowIndex = na
var string lastLowType = ""

if newSwingHigh
    prevSwingHigh := lastSwingHigh
    lastSwingHigh := ph
    lastSwingHighIndex := pivotIndex
    lastHighType := na(prevSwingHigh) ? "SH" : ph > prevSwingHigh ? "HH" : "LH"
    if showSwings
        label.new(pivotIndex, ph, lastHighType, xloc=xloc.bar_index, style=label.style_label_down, textcolor=color.white, color=color.new(bearColor, 15), size=size.tiny)

if newSwingLow
    prevSwingLow := lastSwingLow
    lastSwingLow := pl
    lastSwingLowIndex := pivotIndex
    lastLowType := na(prevSwingLow) ? "SL" : pl > prevSwingLow ? "HL" : "LL"
    if showSwings
        label.new(pivotIndex, pl, lastLowType, xloc=xloc.bar_index, style=label.style_label_up, textcolor=color.white, color=color.new(bullColor, 15), size=size.tiny)

//=============================================================================
// 5. Market Structure Engine
//=============================================================================
var int trend = TREND_NEUTRAL
var string lastStructureEvent = "None"

if newSwingHigh or newSwingLow
    bool bullishStructure = not na(prevSwingHigh) and not na(prevSwingLow) and lastSwingHigh > prevSwingHigh and lastSwingLow > prevSwingLow
    bool bearishStructure = not na(prevSwingHigh) and not na(prevSwingLow) and lastSwingHigh < prevSwingHigh and lastSwingLow < prevSwingLow
    trend := bullishStructure ? TREND_BULL : bearishStructure ? TREND_BEAR : trend

//=============================================================================
// 6. BOS Engine
//=============================================================================
var float lastBullBosLevel = na
var float lastBearBosLevel = na
bool bullBosCandidate = showBos and not na(lastSwingHigh) and breakHighSource > lastSwingHigh + breakBuffer
bool bearBosCandidate = showBos and not na(lastSwingLow) and breakLowSource < lastSwingLow - breakBuffer
bool bullishBOS = bullBosCandidate and (na(lastBullBosLevel) or lastBullBosLevel != lastSwingHigh)
bool bearishBOS = bearBosCandidate and (na(lastBearBosLevel) or lastBearBosLevel != lastSwingLow)

if bullishBOS
    lastBullBosLevel := lastSwingHigh
    lastStructureEvent := "Bullish BOS"
    line.new(lastSwingHighIndex, lastSwingHigh, bar_index, lastSwingHigh, xloc=xloc.bar_index, color=bullColor, width=2)
    label.new(bar_index, lastSwingHigh, "BOS", style=label.style_label_down, textcolor=color.white, color=color.new(bullColor, 0), size=size.small)

if bearishBOS
    lastBearBosLevel := lastSwingLow
    lastStructureEvent := "Bearish BOS"
    line.new(lastSwingLowIndex, lastSwingLow, bar_index, lastSwingLow, xloc=xloc.bar_index, color=bearColor, width=2)
    label.new(bar_index, lastSwingLow, "BOS", style=label.style_label_up, textcolor=color.white, color=color.new(bearColor, 0), size=size.small)

//=============================================================================
// 7. CHoCH Engine
//=============================================================================
bool bullishCHoCH = showChoch and bullishBOS and trend == TREND_BEAR
bool bearishCHoCH = showChoch and bearishBOS and trend == TREND_BULL

if bullishCHoCH
    lastStructureEvent := "Bullish CHoCH"
    label.new(bar_index, low, "CHoCH", style=label.style_label_up, textcolor=color.white, color=color.new(bullColor, 0), size=size.small)

if bearishCHoCH
    lastStructureEvent := "Bearish CHoCH"
    label.new(bar_index, high, "CHoCH", style=label.style_label_down, textcolor=color.white, color=color.new(bearColor, 0), size=size.small)

if bullishBOS
    trend := TREND_BULL
if bearishBOS
    trend := TREND_BEAR

//=============================================================================
// 8. Liquidity Engine
//=============================================================================
float liqTolerance = atr * equalToleranceAtr
bool equalHigh = showLiquidity and newSwingHigh and not na(prevSwingHigh) and math.abs(ph - prevSwingHigh) <= liqTolerance
bool equalLow = showLiquidity and newSwingLow and not na(prevSwingLow) and math.abs(pl - prevSwingLow) <= liqTolerance
bool buySideSweep = showLiquidity and not na(lastSwingHigh) and high > lastSwingHigh and close < lastSwingHigh
bool sellSideSweep = showLiquidity and not na(lastSwingLow) and low < lastSwingLow and close > lastSwingLow
string liquidityStatus = buySideSweep ? "Buy sweep" : sellSideSweep ? "Sell sweep" : equalHigh ? "Equal highs" : equalLow ? "Equal lows" : "None"

if equalHigh
    line liqLine = line.new(lastSwingHighIndex, ph, bar_index + liquidityExtendBars, ph, xloc=xloc.bar_index, extend=extend.none, color=color.new(bearColor, 10), style=line.style_dashed)
    array.push(liquidityLines, liqLine)
    f_trimLines(liquidityLines, 40)

if equalLow
    line liqLine = line.new(lastSwingLowIndex, pl, bar_index + liquidityExtendBars, pl, xloc=xloc.bar_index, extend=extend.none, color=color.new(bullColor, 10), style=line.style_dashed)
    array.push(liquidityLines, liqLine)
    f_trimLines(liquidityLines, 40)

if buySideSweep
    label.new(bar_index, high, "BSL Sweep", style=label.style_label_down, textcolor=color.white, color=color.new(bearColor, 0), size=size.tiny)

if sellSideSweep
    label.new(bar_index, low, "SSL Sweep", style=label.style_label_up, textcolor=color.white, color=color.new(bullColor, 0), size=size.tiny)

//=============================================================================
// 9. Fair Value Gap Engine
//=============================================================================
float gapFilter = math.max(minTickGap, useFvgAtrFilter ? atr * fvgAtrMult : 0.0)
bool bullishFvgCreated = showFvg and bar_index >= 2 and low > high[2] and (low - high[2]) >= gapFilter
bool bearishFvgCreated = showFvg and bar_index >= 2 and high < low[2] and (low[2] - high) >= gapFilter
bool fvgFilled = false

if bullishFvgCreated
    box b = box.new(bar_index - 2, low, bar_index + fvgExtendBars, high[2], xloc=xloc.bar_index, bgcolor=color.new(fvgBullColor, 82), border_color=color.new(fvgBullColor, 30), text="Bull FVG", text_color=color.new(color.white, 25), text_size=size.tiny)
    array.push(fvgBoxes, b)
    array.push(fvgDirs, DIR_BULL)
    f_trimBoxes(fvgBoxes, fvgDirs, maxFvgs)

if bearishFvgCreated
    box b = box.new(bar_index - 2, low[2], bar_index + fvgExtendBars, high, xloc=xloc.bar_index, bgcolor=color.new(fvgBearColor, 82), border_color=color.new(fvgBearColor, 30), text="Bear FVG", text_color=color.new(color.white, 25), text_size=size.tiny)
    array.push(fvgBoxes, b)
    array.push(fvgDirs, DIR_BEAR)
    f_trimBoxes(fvgBoxes, fvgDirs, maxFvgs)

if array.size(fvgBoxes) > 0
    for i = array.size(fvgBoxes) - 1 to 0 by -1
        box b = array.get(fvgBoxes, i)
        int dir = array.get(fvgDirs, i)
        box.set_right(b, bar_index + fvgExtendBars)
        float top = box.get_top(b)
        float bottom = box.get_bottom(b)
        bool partialFill = dir == DIR_BULL ? low < top : high > bottom
        bool completeFill = dir == DIR_BULL ? low <= bottom : high >= top
        if partialFill and not completeFill
            box.set_bgcolor(b, color.new(dir == DIR_BULL ? fvgBullColor : fvgBearColor, 90))
        if completeFill
            fvgFilled := true
            if deleteFilledFvg
                box.delete(b)
                array.remove(fvgBoxes, i)
                array.remove(fvgDirs, i)
            else
                box.set_bgcolor(b, color.new(neutralColor, 92))
                box.set_border_color(b, color.new(neutralColor, 60))

//=============================================================================
// 10. Order Block Engine
//=============================================================================
var float lastBearOpen = na
var float lastBearHigh = na
var float lastBearLow = na
var int lastBearIndex = na
var float lastBullOpen = na
var float lastBullHigh = na
var float lastBullLow = na
var int lastBullIndex = na
bool obTouched = false

if close < open
    lastBearOpen := open
    lastBearHigh := high
    lastBearLow := low
    lastBearIndex := bar_index

if close > open
    lastBullOpen := open
    lastBullHigh := high
    lastBullLow := low
    lastBullIndex := bar_index

if showOb and bullishBOS and not na(lastBearIndex)
    box b = box.new(lastBearIndex, lastBearHigh, bar_index + obExtendBars, lastBearLow, xloc=xloc.bar_index, bgcolor=color.new(obBullColor, 84), border_color=color.new(obBullColor, 25), text="Bull OB", text_color=color.new(color.white, 25), text_size=size.tiny)
    array.push(obBoxes, b)
    array.push(obDirs, DIR_BULL)
    f_trimBoxes(obBoxes, obDirs, maxObs)

if showOb and bearishBOS and not na(lastBullIndex)
    box b = box.new(lastBullIndex, lastBullHigh, bar_index + obExtendBars, lastBullLow, xloc=xloc.bar_index, bgcolor=color.new(obBearColor, 84), border_color=color.new(obBearColor, 25), text="Bear OB", text_color=color.new(color.white, 25), text_size=size.tiny)
    array.push(obBoxes, b)
    array.push(obDirs, DIR_BEAR)
    f_trimBoxes(obBoxes, obDirs, maxObs)

if array.size(obBoxes) > 0
    for i = array.size(obBoxes) - 1 to 0 by -1
        box b = array.get(obBoxes, i)
        int dir = array.get(obDirs, i)
        box.set_right(b, bar_index + obExtendBars)
        float top = box.get_top(b)
        float bottom = box.get_bottom(b)
        bool touched = high >= bottom and low <= top
        bool invalid = dir == DIR_BULL ? close < bottom : close > top
        if touched
            obTouched := true
            box.set_bgcolor(b, color.new(dir == DIR_BULL ? obBullColor : obBearColor, 90))
        if invalid and removeInvalidOb
            if showBreakerBlocks
                label.new(bar_index, dir == DIR_BULL ? bottom : top, "Breaker", style=dir == DIR_BULL ? label.style_label_down : label.style_label_up, textcolor=color.white, color=color.new(neutralColor, 0), size=size.tiny)
            box.delete(b)
            array.remove(obBoxes, i)
            array.remove(obDirs, i)

//=============================================================================
// 11. Premium / Discount Engine
//=============================================================================
float rangeHigh = lastSwingHigh
float rangeLow = lastSwingLow
bool validRange = showPd and not na(rangeHigh) and not na(rangeLow) and rangeHigh > rangeLow
float eq = validRange ? (rangeHigh + rangeLow) * 0.5 : na
float oteTop = validRange ? rangeHigh - (rangeHigh - rangeLow) * 0.62 : na
float oteBottom = validRange ? rangeHigh - (rangeHigh - rangeLow) * 0.79 : na
bool inDiscount = validRange and close <= eq
bool inPremium = validRange and close >= eq
bool inOte = validRange and close <= oteTop and close >= oteBottom

if validRange
    int left = math.max(0, bar_index - pdExtendBars)
    int right = bar_index + pdExtendBars
    if na(premiumBox)
        premiumBox := box.new(left, rangeHigh, right, eq, xloc=xloc.bar_index, bgcolor=color.new(bearColor, 93), border_color=color.new(bearColor, 85), text="Premium", text_color=color.new(bearColor, 25), text_size=size.tiny)
        discountBox := box.new(left, eq, right, rangeLow, xloc=xloc.bar_index, bgcolor=color.new(bullColor, 93), border_color=color.new(bullColor, 85), text="Discount", text_color=color.new(bullColor, 25), text_size=size.tiny)
        oteBox := box.new(left, oteTop, right, oteBottom, xloc=xloc.bar_index, bgcolor=color.new(color.yellow, 88), border_color=color.new(color.yellow, 40), text="OTE", text_color=color.new(color.black, 0), text_size=size.tiny)
        eqLine := line.new(left, eq, right, eq, xloc=xloc.bar_index, color=color.new(neutralColor, 20), style=line.style_dotted)
    else
        box.set_lefttop(premiumBox, left, rangeHigh)
        box.set_rightbottom(premiumBox, right, eq)
        box.set_lefttop(discountBox, left, eq)
        box.set_rightbottom(discountBox, right, rangeLow)
        box.set_lefttop(oteBox, left, oteTop)
        box.set_rightbottom(oteBox, right, oteBottom)
        line.set_xy1(eqLine, left, eq)
        line.set_xy2(eqLine, right, eq)

//=============================================================================
// 12. Multi-Timeframe Engine
//=============================================================================
int htfTrend = showMtf ? request.security(syminfo.tickerid, htf, close > ta.sma(close, htfTrendLen) ? TREND_BULL : close < ta.sma(close, htfTrendLen) ? TREND_BEAR : TREND_NEUTRAL, barmerge.gaps_off, barmerge.lookahead_off) : trend
bool htfBullBos = showMtf ? request.security(syminfo.tickerid, htf, close > ta.highest(high, pivotLen * 4)[1], barmerge.gaps_off, barmerge.lookahead_off) : bullishBOS
bool htfBearBos = showMtf ? request.security(syminfo.tickerid, htf, close < ta.lowest(low, pivotLen * 4)[1], barmerge.gaps_off, barmerge.lookahead_off) : bearishBOS
bool htfBullFvg = showMtf ? request.security(syminfo.tickerid, htf, low > high[2], barmerge.gaps_off, barmerge.lookahead_off) : bullishFvgCreated
bool htfBearFvg = showMtf ? request.security(syminfo.tickerid, htf, high < low[2], barmerge.gaps_off, barmerge.lookahead_off) : bearishFvgCreated
string htfEvent = htfBullBos ? "Bull BOS" : htfBearBos ? "Bear BOS" : htfBullFvg ? "Bull FVG" : htfBearFvg ? "Bear FVG" : "None"

//=============================================================================
// 13. Dashboard
//=============================================================================
int activeBullFvgs = f_countDir(fvgDirs, DIR_BULL)
int activeBearFvgs = f_countDir(fvgDirs, DIR_BEAR)
int activeBullObs = f_countDir(obDirs, DIR_BULL)
int activeBearObs = f_countDir(obDirs, DIR_BEAR)
string riskLevel = (buySideSweep or sellSideSweep) and (bullishBOS or bearishBOS) ? "High" : trend == TREND_NEUTRAL ? "Medium" : "Normal"

if showDashboard and barstate.islast
    table.cell(dash, 0, 0, "Trend", text_color=color.white)
    table.cell(dash, 1, 0, f_trendText(trend), text_color=color.white, bgcolor=color.new(f_trendColor(trend), 45))
    table.cell(dash, 0, 1, "HTF Trend", text_color=color.white)
    table.cell(dash, 1, 1, f_trendText(htfTrend), text_color=color.white, bgcolor=color.new(f_trendColor(htfTrend), 45))
    table.cell(dash, 0, 2, "Structure", text_color=color.white)
    table.cell(dash, 1, 2, lastStructureEvent, text_color=color.white)
    table.cell(dash, 0, 3, "HTF Event", text_color=color.white)
    table.cell(dash, 1, 3, htfEvent, text_color=color.white)
    table.cell(dash, 0, 4, "Active FVG", text_color=color.white)
    table.cell(dash, 1, 4, str.tostring(array.size(fvgBoxes)) + " (B " + str.tostring(activeBullFvgs) + " / S " + str.tostring(activeBearFvgs) + ")", text_color=color.white)
    table.cell(dash, 0, 5, "Active OB", text_color=color.white)
    table.cell(dash, 1, 5, str.tostring(array.size(obBoxes)) + " (B " + str.tostring(activeBullObs) + " / S " + str.tostring(activeBearObs) + ")", text_color=color.white)
    table.cell(dash, 0, 6, "Liquidity", text_color=color.white)
    table.cell(dash, 1, 6, liquidityStatus, text_color=color.white)
    table.cell(dash, 0, 7, "Session", text_color=color.white)
    table.cell(dash, 1, 7, f_sessionName(), text_color=color.white)
    table.cell(dash, 0, 8, "Risk", text_color=color.white)
    table.cell(dash, 1, 8, riskLevel, text_color=color.white, bgcolor=color.new(riskLevel == "High" ? bearColor : neutralColor, 55))

//=============================================================================
// 14. Smart Signal Engine
//=============================================================================
bool volumeOk = not requireVolumeConfirm or volume > ta.sma(volume, volumeMaLen)
bool buyConfluence = showSignals and htfTrend == TREND_BULL and f_recent(bullishBOS, recentBars) and f_recent(bullishCHoCH, recentBars) and inDiscount and activeBullFvgs > 0 and activeBullObs > 0 and f_recent(sellSideSweep, recentBars) and volumeOk
bool sellConfluence = showSignals and htfTrend == TREND_BEAR and f_recent(bearishBOS, recentBars) and f_recent(bearishCHoCH, recentBars) and inPremium and activeBearFvgs > 0 and activeBearObs > 0 and f_recent(buySideSweep, recentBars) and volumeOk
bool buySignal = buyConfluence and not buyConfluence[1]
bool sellSignal = sellConfluence and not sellConfluence[1]

float buyEntry = close
float buyStop = validRange ? rangeLow : close - atr
float buyRisk = math.max(buyEntry - buyStop, syminfo.mintick)
float sellEntry = close
float sellStop = validRange ? rangeHigh : close + atr
float sellRisk = math.max(sellStop - sellEntry, syminfo.mintick)

if buySignal
    label.new(bar_index, low, "BUY\nEntry " + str.tostring(buyEntry, format.mintick) + "\nSL " + str.tostring(buyStop, format.mintick) + "\nTP1 " + str.tostring(buyEntry + buyRisk * rr1, format.mintick) + "\nTP2 " + str.tostring(buyEntry + buyRisk * rr2, format.mintick) + "\nTP3 " + str.tostring(buyEntry + buyRisk * rr3, format.mintick), style=label.style_label_up, color=color.new(bullColor, 0), textcolor=color.white, size=size.normal)

if sellSignal
    label.new(bar_index, high, "SELL\nEntry " + str.tostring(sellEntry, format.mintick) + "\nSL " + str.tostring(sellStop, format.mintick) + "\nTP1 " + str.tostring(sellEntry - sellRisk * rr1, format.mintick) + "\nTP2 " + str.tostring(sellEntry - sellRisk * rr2, format.mintick) + "\nTP3 " + str.tostring(sellEntry - sellRisk * rr3, format.mintick), style=label.style_label_down, color=color.new(bearColor, 0), textcolor=color.white, size=size.normal)

plotshape(buySignal, title="BUY Signal", style=shape.triangleup, location=location.belowbar, color=bullColor, size=size.small, text="BUY")
plotshape(sellSignal, title="SELL Signal", style=shape.triangledown, location=location.abovebar, color=bearColor, size=size.small, text="SELL")

//=============================================================================
// 15. Alerts
//=============================================================================
alertcondition(bullishBOS, title="Bullish BOS", message="SMC Pro: Bullish break of structure")
alertcondition(bearishBOS, title="Bearish BOS", message="SMC Pro: Bearish break of structure")
alertcondition(bullishCHoCH, title="Bullish CHoCH", message="SMC Pro: Bullish change of character")
alertcondition(bearishCHoCH, title="Bearish CHoCH", message="SMC Pro: Bearish change of character")
alertcondition(bullishFvgCreated, title="Bullish FVG Created", message="SMC Pro: Bullish fair value gap created")
alertcondition(bearishFvgCreated, title="Bearish FVG Created", message="SMC Pro: Bearish fair value gap created")
alertcondition(fvgFilled, title="FVG Filled", message="SMC Pro: Fair value gap filled")
alertcondition(obTouched, title="Order Block Touch", message="SMC Pro: Order block touched")
alertcondition(buySideSweep or sellSideSweep, title="Liquidity Sweep", message="SMC Pro: Liquidity sweep detected")
alertcondition(buySignal, title="BUY", message="SMC Pro: BUY confluence signal")
alertcondition(sellSignal, title="SELL", message="SMC Pro: SELL confluence signal")

//=============================================================================
// 16. Sessions & Performance Optimizations
//=============================================================================
bgcolor(showSessions and f_inSession(asianSession) ? color.new(color.blue, 94) : na, title="Asian Session")
bgcolor(showSessions and f_inSession(londonSession) ? color.new(color.green, 94) : na, title="London Kill Zone")
bgcolor(showSessions and f_inSession(nySession) ? color.new(color.orange, 94) : na, title="New York Kill Zone")

plot(showSwings ? lastSwingHigh : na, title="Last Confirmed Swing High", color=color.new(bearColor, 70), style=plot.style_linebr)
plot(showSwings ? lastSwingLow : na, title="Last Confirmed Swing Low", color=color.new(bullColor, 70), style=plot.style_linebr)
